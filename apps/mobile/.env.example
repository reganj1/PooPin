# Copy this file to apps/mobile/.env.local for local Expo development.
# For Expo Go on a physical iPhone, EXPO_PUBLIC_API_BASE_URL must be a URL
# your phone can reach, such as your Mac's LAN IP or your deployed web URL.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
