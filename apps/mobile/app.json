{
  "expo": {
    "name": "Poopin",
    "slug": "poopin-mobile",
    "scheme": "poopin",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.poopin.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Poopin uses your location to show nearby restrooms.",
        "NSPhotoLibraryUsageDescription": "Poopin needs access to your photo library to upload restroom photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Poopin needs access to your photo library to upload restroom photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d2ce0c91-0ea4-40ce-b3ad-f78de33b2222"
      }
    },
    "android": {
      "package": "com.poopin.app"
    }
  }
}
